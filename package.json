{
  "name": "ergonomic-comic-translator",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "api": "bun run src/api/server.ts",
    "ocr": "bun run src/main.ts",
    "doctor": "bun run src/scripts/doctor.ts",
    "system:detect": "bun run src/scripts/system-detect.ts",
    "system:bootstrap": "bun run src/scripts/system-bootstrap.ts",
    "python:detect": "bun run src/scripts/python-detect.ts",
    "python:bootstrap": "bun run src/scripts/python-bootstrap.ts",
    "nvidia:detect": "bun run src/scripts/nvidia-detect.ts",
    "amd:detect": "bun run src/scripts/amd-detect.ts",
    "cuda:detect": "bun run src/scripts/cuda-detect.ts",
    "textless": "bun run src/scripts/textless.ts",
    "translate": "bun run src/scripts/translate.ts",
    "context": "bun run src/scripts/context.ts",
    "delete": "bun run src/scripts/delete.ts",
    "text-cleaner:bootstrap": "bun run src/scripts/text-cleaner-bootstrap.ts",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "typecheck:frontend": "bunx tsc -p tsconfig.frontend.json --noEmit",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "preview:frontend": "vite preview"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/log4js": "^2.3.5",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "fflate": "^0.8.2",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "log4js": "^6.9.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0"
  }
}
